# Font
font=JetBrainsMono Nerd Font 10

# Position
anchor=top-right
margin=15
padding=12
width=350
height=120

# Rounded corners
border-radius=10

# Colors (Catppuccin Mocha)
background-color=#1e1e2ee6
text-color=#cdd6f4ff
border-color=#89b4fae6
progress-color=over #89b4fa

# Border
border-size=2

# Icons
icons=1
max-icon-size=48
icon-path=/usr/share/icons/Papirus-Dark

# Timing
default-timeout=5000
ignore-timeout=0

# Grouping
group-by=summary
sort=-time

# Markup
markup=1

# Actions
on-button-left=invoke-default-action
on-button-right=dismiss
on-button-middle=dismiss-all

# History
history=1
max-history=20

# Extra
layer=overlay
